<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="24dp">

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Monthly Goals"
        android:textSize="24sp"
        android:textStyle="bold"
        android:layout_marginBottom="24dp"/>

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Minimum Monthly Goal"
        android:layout_marginBottom="8dp"/>

    <EditText
        android:id="@+id/etMinGoal"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:hint="e.g. 500"
        android:inputType="numberDecimal"
        android:layout_marginBottom="12dp"/>

    <SeekBar
        android:id="@+id/sbMinGoal"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:max="5000"
        android:layout_marginBottom="24dp"/>

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Maximum Monthly Goal"
        android:layout_marginBottom="8dp"/>

    <EditText
        android:id="@+id/etMaxGoal"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:hint="e.g. 2000"
        android:inputType="numberDecimal"
        android:layout_marginBottom="12dp"/>

    <SeekBar
        android:id="@+id/sbMaxGoal"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:max="10000"
        android:layout_marginBottom="32dp"/>

    <Button
        android:id="@+id/btnSaveGoals"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Save Goals"/>

</LinearLayout>